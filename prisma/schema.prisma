// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// --- Arsitektur Dasar ala Note.com ---
// Tabel User Utama
model User {
  id            String    @id @default(cuid())
  name          String?
  handle        String?   @unique // <--- TAMBAHIN INI (Username unik)
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Cuma keisi kalau dia daftar manual (bukan Google/Github)
  bio           String?
  folders       Folder[] 

  // --- TAMBAHAN BARU BUAT CLI ---
  cliToken      String?   @unique // Token rahasia buat nge-push file
  comments      Comment[]
  
  accounts      Account[]
  sessions      Session[]
  posts         Post[]   
  likes       Like[]
  bookmarks   Bookmark[]

  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
// --- TABEL FOLDER (TABEL BARU) ---
model Folder {
  id        String   @id @default(cuid())
  name      String
  
  // Relasi Pemilik Folder
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relasi Induk & Anak (Self-Relation)
  parentId  String?  // Kalau null berarti di paling luar (Root)
  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderHierarchy")
  
  // Relasi ke Artikel (Satu folder bisa punya banyak post)
  posts     Post[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // Biar query folder berdasarkan user makin ngebut
}

// Tabel Account (Buat nampung data dari Google/Github)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique // URL ramah SEO, misal: /judul-artikel-keren
  content    Json?    // Kita pakai Json karena nanti editornya pakai block style (Tiptap/Editor.js)
  published  Boolean  @default(false)
  coverImage String?  // Gambar header artikel
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Relasi Folder (Tambahan Baru)
  rawContent  String?   @db.Text

  folderId   String?  // Kalau null berarti filenya ada di luar (Root)
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  views       Int      @default(0)
  likesCount  Int       @default(0) // Biar gampang ngitung total like
  likes       Like[]
  bookmarks   Bookmark[]
  tags   String[]  @default([])
  comments    Comment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug]) // Biar pencarian artikel via URL makin ngebut
  @@index([folderId]) // Biar nyari artikel di dalem folder makin cepet
}

// --- BIKIN 2 MODEL BARU INI DI BAWAH ---
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // 1 user cuma bisa like 1 kali per artikel
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // 1 user cuma bisa bookmark 1 kali per artikel
}

model Comment {
   id        String    @id @default(cuid())
   content   String
   createdAt DateTime  @default(now())
   updatedAt DateTime  @updatedAt
   postId    String
   authorId  String
   parentId  String?

   post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
   author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
   parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
   replies   Comment[] @relation("CommentReplies")
}

model Follow {
   id          String   @id @default(cuid())
   followerId  String
   followingId String
   createdAt   DateTime @default(now())

   follower    User     @relation("UserFollowers",  fields: [followerId],  references: [id], onDelete: Cascade)
   following   User     @relation("UserFollowing",  fields: [followingId], references: [id], onDelete: Cascade)

   @@unique([followerId, followingId])
   @@index([followerId])
   @@index([followingId])
}